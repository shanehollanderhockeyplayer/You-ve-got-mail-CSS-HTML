#workskin .window {
  text-align: justify;
  margin-left: auto;
  margin-right: auto;
  margin-top: 0;
  margin-bottom: 0;
}

#workskin .textfield_dark {
  border-color: #cfcfcf;
  border-style: solid;
  border-width: 1px;
  border-bottom: none;
  margin-top: 0;
  margin-bottom: 0;
  width: 66%;
  padding: 2px;
  color: #E8EAED;
  background-color: #383B43;
}


#workskin .ebody_dark {
  position: relative;
  width: 66%;
  padding-top: 0;
  padding-bottom: 0;
  padding-left: 2px;
  padding-right: 2px;
  text-align: justify;
  color: #E8EAED;
  background-color: #383B43;
  margin-left: auto;
  margin-right: auto;
  overflow: auto;
  display: block;
  height: 250px;
  border-color: #cfcfcf;
  border-style: solid;
  border-width: 1px;
}


#workskin .buttonbar_dark {
  border-color: #cfcfcf;
  background-color: #2F3138;
  color: #E8EAED;
  border-style: solid;
  border-width: 1px;
  border-top: none;
  margin-top: 0;
  margin-bottom: 50px;
  width: 66%;
  padding: 2px;
  height: 1.5em;
  overflow: hidden;
  text-overflow: clip;
}

#workskin .buttonbar_dark:after {
  content: 'Reply | Forward | Delete';
  display: inline-block;
  position: relative;
  float: left;
  padding: 0 3px;
  cursor: pointer;
}



#workskin .topbar_dark {
  background-color: #401617;
  color: #FFFFFF;
  border-color: #401617;
  border-style: solid;
  border-width: 1px;
  margin-top: 0;
  margin-bottom: 0;
  width: 66%;
  padding: 2px;
  height: 1.5em;
  overflow: hidden;
  text-overflow: clip;
}

#workskin .topbar_dark:before {
  content: 'Email';
  display: inline-block;
  position: relative;
  float: left;
  font-weight: bold;
  padding: 0 3px;
  width: 85%;
}

#workskin .topbar_dark:after {
  content: ' _ X';
  display: inline-block;
  position: relative;
  font-weight: bold;
  padding-right: 5px;
  float: right;
  color: #cfcfcf;
  -webkit-transform: scale(1.5, 1.0);
  -moz-transform: scale(1.5, 1.0);
  -ms-transform: scale(1.5, 1.0);
  -o-transform: scale(1.5, 1.0);
  transform: scale(1.5,1.0);
  cursor: pointer;
}
